{
  "name": "openkestrel",
  "version": "0.1.0",
  "private": true,
  "description": "OpenKestrel monorepo workspace",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "concurrently -n web,admin -c cyan,magenta \"pnpm dev:web\" \"pnpm dev:admin\"",
    "dev:web": "dotenv -e .env -- pnpm --filter @openkestrel/web dev",
    "dev:admin": "dotenv -e .env -- pnpm --filter @openkestrel/admin dev",
    "format": "biome format --write . && pnpm format:md",
    "format:check": "biome format . && pnpm format:md:check",
    "format:md": "prettier --write \"**/*.md\"",
    "format:md:check": "prettier --check \"**/*.md\"",
    "lint": "biome check . && pnpm -r --if-present lint:framework",
    "lint:biome": "biome check .",
    "build": "pnpm -r build",
    "build:web": "dotenv -e .env -- pnpm --filter @openkestrel/web build",
    "build:admin": "dotenv -e .env -- pnpm --filter @openkestrel/admin build",
    "start:web": "dotenv -e .env -- pnpm --filter @openkestrel/web start",
    "start:admin": "dotenv -e .env -- pnpm --filter @openkestrel/admin start",
    "orchestrate": "dotenv -e .env -- pnpm --filter @openkestrel/web orchestrate",
    "okdep:build": "pnpm --filter @openkestrel/dep-graph build",
    "okdep": "pnpm --filter @openkestrel/dep-graph okdep",
    "docs:verify:claude": "node scripts/verify-claude-l2.mjs"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@eslint/eslintrc": "^3.3.4",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "prettier": "^3.6.2"
  }
}
